# ─────────────────────────────────────────────────────────────────────────────
# Storefront API — environment configuration
# Copy this file to .env and fill in the values marked CHANGE_ME / required.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
STOREFRONT_ENV=development
STOREFRONT_API_BASE_URL=http://localhost:8001
STOREFRONT_WEB_BASE_URL=http://localhost:3000  # comma-separated for multiple origins, e.g. https://persona.com,http://localhost:3000
STOREFRONT_LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────────────────────
# Shared PostgreSQL instance with the Node backend.
# The storefront only reads/writes to the "web" schema.
DATABASE_URL=postgresql+asyncpg://persona:CHANGE_ME@localhost:5432/persona
STOREFRONT_DB_SCHEMA=web

# ─── Redis ───────────────────────────────────────────────────────────────────
# Uses DB index 1 to avoid colliding with Node / BullMQ on index 0.
STOREFRONT_REDIS_URL=redis://localhost:6379/1

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=persona-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=true
STOREFRONT_S3_PREFIX=web

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT_SECRET should be at least 32 random characters.
JWT_SECRET=CHANGE_ME_random_string_with_at_least_32_chars
STOREFRONT_JWT_EXPIRY_HOURS=720
STOREFRONT_GUEST_COOKIE_SECRET=CHANGE_ME_long_random_string
STOREFRONT_ADMIN_API_KEY=CHANGE_ME_admin_key

# ─── Mercado Pago ────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
# Optional — recommended in production to validate webhook signatures.
MERCADOPAGO_WEBHOOK_SECRET=

# ─── OpenAI (script writer) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── kie.ai — Nano Banana Pro (multi-character composite) ────────────────────
# Required when orders have more than one character.
# Get your key at https://kie.ai
KIE_API_KEY=your_kie_api_key_here
KIE_API_BASE=https://api.kie.ai/api/v1
KIE_NANO_BANANA_MODEL=google/nano-banana-pro
# Optional: webhook URL for kie.ai async callbacks (leave blank for polling).
KIE_CALLBACK_URL=

# ─── xAI Grok Imagine Video (image-to-video) ─────────────────────────────────
# Required for video generation.
# Get your key at https://console.x.ai
XAI_API_KEY=your_xai_api_key_here
XAI_API_BASE=https://api.x.ai/v1
XAI_VIDEO_MODEL=grok-imagine-video
XAI_VIDEO_DURATION_SECONDS=10
XAI_VIDEO_ASPECT_RATIO=9:16
XAI_VIDEO_RESOLUTION=720p

# ─── WhatsApp delivery (Evolution API) ───────────────────────────────────────
# Only needed if WhatsApp delivery is enabled.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME_generate_a_random_key
EVOLUTION_INSTANCE_NAME=persona-bot

# ─── Batch policy ────────────────────────────────────────────────────────────
BATCH_AUTO_THRESHOLD=5
BATCH_MAX_AGE_MINUTES=60
BATCH_CONCURRENCY=4
